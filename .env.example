# ───── Şimşek Mobilya & Mimarlık ─────

# Public site URL (used by metadata, JSON-LD, sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──── Optional: contact-form e-mail backend ────
# Set RESEND_API_KEY to forward submissions via Resend (https://resend.com).
# When unset, submissions are still validated and logged — the form keeps
# working out of the box, you can wire e-mail later.
RESEND_API_KEY=""
CONTACT_EMAIL_TO="info@simsekmobilya.com"
CONTACT_EMAIL_FROM="noreply@simsekmobilya.com"

# ──── E-commerce ────

# Postgres connection. Local dev: docker postgres or `prisma dev` (Neon).
# Production: Neon pooled URL (?sslmode=require&pgbouncer=true&connect_timeout=15)
DATABASE_URL=""
# Direct (non-pooled) connection used by `prisma migrate`. Neon: same DB, no
# pgbouncer flags. Without this, migrations fail under pooled connections.
DIRECT_URL=""

# JWT signing — generate with `openssl rand -base64 48`.
# Minimum 32 characters. Rotate by setting JWT_SECRET_PREVIOUS to old value
# (dual-verify pattern, Phase D+ T33).
JWT_SECRET=""

# Vercel Blob (admin product image uploads). Phase E.
# `vercel blob` CLI to provision, or via Vercel dashboard.
BLOB_READ_WRITE_TOKEN=""

# ──── Rate limiting (optional but recommended for production) ────
# Cross-instance rate limiting for auth/order/track endpoints. When unset, the
# limiter falls back to per-process memory, which under-counts on Vercel fluid
# compute (each instance limits independently). Provision an Upstash Redis
# database (https://upstash.com) and paste its REST URL + token here.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Initial admin seeded by `npm run db:seed`. Change before running!
SEED_ADMIN_EMAIL="admin@simsekmobilya.com"
SEED_ADMIN_PASSWORD=""
