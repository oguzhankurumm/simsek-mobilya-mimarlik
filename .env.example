# Public site URL (used by metadata, JSON-LD, sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──── Optional: contact-form e-mail backend ────
# Set RESEND_API_KEY to forward submissions via Resend (https://resend.com).
# When unset, submissions are still validated and logged — the form keeps
# working out of the box, you can wire e-mail later.
RESEND_API_KEY=""
CONTACT_EMAIL_TO="info@simsekmobilya.com"
CONTACT_EMAIL_FROM="noreply@simsekmobilya.com"
