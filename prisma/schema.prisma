// Şimşek Mobilya & Mimarlık — Prisma schema
// Money note: all Decimal(10,2) fields are TL (kuruş = 0.01 TL precision).
// Application code converts to/from INTEGER kuruş at the boundary
// (see src/lib/money.ts). Never do math on Decimal directly in JS.
// Token note: Session.tokenHash and PasswordReset.codeHash store sha256
// of the raw value. Raw token only lives in the cookie / email body.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAYMENT_RECEIVED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?    @unique
  name         String
  passwordHash String
  role         UserRole   @default(CUSTOMER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  orders       Order[]
  addresses    Address[]
  wishlist     Wishlist[]
  sessions     Session[]

  @@index([email])
  @@index([phone])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  imageUrl     String    @default("")
  description  String    @default("")
  displayOrder Int       @default(0)
  active       Boolean   @default(true)
  products     Product[]

  @@index([slug])
  @@index([active, displayOrder])
}

model Product {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  categoryId      String
  category        Category            @relation(fields: [categoryId], references: [id])
  // Price in TL. Convert via src/lib/money.ts.
  originalPrice   Decimal             @db.Decimal(10, 2)
  salePrice       Decimal             @db.Decimal(10, 2)
  discountPercent Int                 @default(0)
  description     String              @default("")
  brand           String              @default("Şimşek Mobilya")
  stock           Int                 @default(0)
  featured        Boolean             @default(false)
  active          Boolean             @default(true)
  // Furniture-specific fields (Phase 2+3 review finding T03)
  widthCm         Int?
  depthCm         Int?
  heightCm        Int?
  material        String[] // ahşap, mdf, metal, tekstil...
  color           String[] // antrasit, ceviz, beyaz...
  room            String? // salon, yatak-odasi, mutfak...
  leadTimeDays    Int?     @default(0) // 0 = stoktan, >0 = ölçüye özel (future)
  images          ProductImage[]
  tags            String[]
  orderItems      OrderItem[]
  wishlist        Wishlist[]
  notifications   StockNotification[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([featured, active])
  @@index([active, createdAt])
  @@index([room])
}

model ProductImage {
  id           String  @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url          String
  altText      String  @default("")
  displayOrder Int     @default(0)
  isMain       Boolean @default(false)

  @@index([productId])
}

model StockNotification {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  email       String?
  phone       String?
  createdAt   DateTime  @default(now())
  notifiedAt  DateTime?

  @@index([productId])
  @@index([notifiedAt])
}

model Iban {
  id            String   @id @default(cuid())
  title         String
  bankName      String
  accountHolder String
  ibanNumber    String
  active        Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  orders        Order[]

  @@index([active, displayOrder])
}

model WhatsappLine {
  id           String  @id @default(cuid())
  label        String
  number       String
  numberE164   String  @default("")
  active       Boolean @default(true)
  displayOrder Int     @default(0)
  orders       Order[]

  @@index([active, displayOrder])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique // server-generated 8-char random + check digit
  idempotencyKey  String?       @unique // POST /api/orders header sha256
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestName       String?
  guestPhone      String?       // E.164 normalized
  guestEmail      String?
  items           OrderItem[]
  // Total in TL. Computed server-side from products + qty (never trust client).
  totalAmount     Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(PENDING)
  ibanId          String?
  iban            Iban?         @relation(fields: [ibanId], references: [id])
  whatsappLineId  String?
  whatsappLine    WhatsappLine? @relation(fields: [whatsappLineId], references: [id])
  receiptImageUrl String?
  notes           String?
  acceptedTerms   Boolean       @default(false) // mesafeli satış sözleşmesi onayı
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderNumber])
  @@index([idempotencyKey])
  @@index([userId])
  @@index([guestPhone])
  @@index([status])
  @@index([status, createdAt])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  // Snapshot at order time — product fields can change later.
  productName   String
  productImage  String  @default("")
  originalPrice Decimal @db.Decimal(10, 2)
  salePrice     Decimal @db.Decimal(10, 2)
  quantity      Int
  subtotal      Decimal @db.Decimal(10, 2)

  @@index([orderId])
}

model HeroSlide {
  id            String  @id @default(cuid())
  imageUrl      String
  title         String
  highlightText String  @default("")
  subtitle      String  @default("")
  badgeText     String  @default("")
  ctaText       String  @default("")
  ctaUrl        String  @default("")
  displayOrder  Int     @default(0)
  active        Boolean @default(true)

  @@index([active, displayOrder])
}

model SiteSettings {
  id                    String   @id @default("singleton")
  siteName              String   @default("Şimşek Mobilya & Mimarlık")
  metaDescription       String   @default("")
  whatsappFloatNumber   String   @default("")
  freeShippingThreshold Decimal  @default(5000) @db.Decimal(10, 2)
  maintenanceMode       Boolean  @default(false)
  // Türk e-ticaret yasal bilgi (P11)
  vkn                   String   @default("") // Vergi Kimlik No
  mersisNo              String   @default("")
  etbisNo               String   @default("") // ETBİS belge no
  legalAddress          String   @default("")
  updatedAt             DateTime @updatedAt
}

model Address {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  fullName    String
  phone       String
  city        String
  district    String
  addressLine String
  isDefault   Boolean @default(false)

  @@index([userId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String   // sha256 of raw 6-digit code
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([codeHash])
  @@index([expiresAt])
}
